# ── AWP Autonomous Bot Config (0 DH Setup) ──

# Your Wallet (Required)
WALLET3_ADDRESS=0x000...
WALLET3_PRIVATE_KEY=your_private_key_here

# Targets to Follow (Copy-trading)
COPY_TARGETS=0xb27281c0079b5a1471d424f6Cd6304AB66A4DDB6,0xa9931966708cbc0ee65f38e43474cbdc0de1e243

# Network Settings
PREDICT_SERVER_URL=https://api.agentpredict.work

# Local LLM Config (Local AI)
# If using Ollama/LM Studio, pointed to host machine:
LLM_BASE_URL=http://host.docker.internal:18789/v1
LLM_MODEL=local-model

# Bot Behavior
INACTIVITY_TIMEOUT=120
POLL_INTERVAL=30
INDEP_COOLDOWN=120

# No Proxies Needed for 0 DH
PROXY_USER=
PROXY_PASS=
NVIDIA_API_KEY=
